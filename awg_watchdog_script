#!/bin/bash

# --- Настройки ---
CONTAINER="amnezia-awg2"
MAX_AGE=150
RESTART_LIMIT=3
LOG_FILE="/var/log/awg_watchdog.log"
STOP_FLAG="/tmp/awg_restart_attempts_count"

# Функция получения хендшейка (возвращает 0, если пусто)
get_last_hs() {
    HS=$(docker exec "$CONTAINER" /usr/bin/wg show all latest-handshakes 2>/dev/null | awk '$3 > 0 {print $3}' | sort -nr | head -n 1)
    echo "${HS:-0}"
}

LAST_HS=$(get_last_hs)
NOW=$(date +%s)
DIFF=$(( NOW - LAST_HS ))

# 1. ПРОВЕРКА: Если связь есть (Handshake свежий)
if [[ "$LAST_HS" -gt 0 && "$DIFF" -lt "$MAX_AGE" ]]; then
    if [[ -f "$STOP_FLAG" ]]; then
        rm -f "$STOP_FLAG"
        echo "$(date '+%Y-%m-%d %H:%M:%S') - СВЯЗЬ ВОССТАНОВЛЕНА. Счетчик сброшен." >> "$LOG_FILE"
    fi
    exit 0
fi

# 2. ПРОВЕРКА ЛИМИТА: Если связь упала, проверяем, не исчерпаны ли попытки
ATTEMPTS=$(cat "$STOP_FLAG" 2>/dev/null || echo 0)

if [[ "$ATTEMPTS" -ge "$RESTART_LIMIT" ]]; then
    # Если это ровно RESTART_LIMIT, запишем в лог один раз о провале
    if [[ "$ATTEMPTS" -eq "$RESTART_LIMIT" ]]; then
        echo "$(date '+%Y-%m-%d %H:%M:%S') - ОШИБКА: Лимит попыток ($RESTART_LIMIT) исчерпан. Рестарты остановлены." >> "$LOG_FILE"
        echo $(( ATTEMPTS + 1 )) > "$STOP_FLAG" # Увеличим до 4, чтобы больше не писать это сообщение
    fi
    exit 0
fi

# 3. ДЕЙСТВИЕ: Рестарт и инкремент счетчика
NEW_ATTEMPTS=$(( ATTEMPTS + 1 ))
echo "$NEW_ATTEMPTS" > "$STOP_FLAG"

echo "$(date '+%Y-%m-%d %H:%M:%S') - Попытка $NEW_ATTEMPTS: Связь потеряна ($DIFF сек). Рестарт контейнера..." >> "$LOG_FILE"
docker restart "$CONTAINER"
